<?xml version="1.0" ?>
<gnn_model name="Continuous State Navigation Agent" version="1.0">
  <metadata>
    <annotation>A continuous-state Active Inference agent navigating a 2D environment:
- Hidden states: 2D position (x, y) as Gaussian belief
- Observations: noisy position measurements with Gaussian noise
- Actions: 2D velocity commands (dx, dy)
- Uses Laplace approximation for Gaussian belief updating
- Generalized coordinates of motion for smooth trajectories</annotation>
    <created_at>2026-03-13T18:17:23.585088</created_at>
    <modified_at>2026-03-13T18:17:23.585088</modified_at>
  </metadata>
