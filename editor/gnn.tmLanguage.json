{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "GNN",
    "scopeName": "source.gnn",
    "fileTypes": [
        "gnn.md"
    ],
    "patterns": [
        {
            "include": "#sections"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#connections"
        },
        {
            "include": "#parameterization"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        }
    ],
    "repository": {
        "sections": {
            "patterns": [
                {
                    "name": "markup.heading.2.gnn",
                    "match": "^##\\s+(GNNSection|GNNVersionAndFlags|ModelName|ModelAnnotation|StateSpaceBlock|Connections|InitialParameterization|Metadata)\\b",
                    "captures": {
                        "0": {
                            "name": "entity.name.section.gnn"
                        }
                    }
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "meta.variable.gnn",
                    "match": "^([A-Za-z_π'][A-Za-z0-9_π']*)\\[([^\\]]+)\\]",
                    "captures": {
                        "1": {
                            "name": "variable.other.gnn"
                        },
                        "2": {
                            "name": "constant.numeric.dimension.gnn"
                        }
                    }
                }
            ]
        },
        "connections": {
            "patterns": [
                {
                    "name": "meta.connection.directed.gnn",
                    "match": "^([A-Za-z_π'][A-Za-z0-9_π']*)>([A-Za-z_π'][A-Za-z0-9_π']*)(?::([A-Za-z0-9_]+))?$",
                    "captures": {
                        "1": {
                            "name": "variable.other.source.gnn"
                        },
                        "2": {
                            "name": "variable.other.target.gnn"
                        },
                        "3": {
                            "name": "entity.name.tag.annotation.gnn"
                        }
                    }
                },
                {
                    "name": "meta.connection.undirected.gnn",
                    "match": "^([A-Za-z_π'][A-Za-z0-9_π']*)-([A-Za-z_π'][A-Za-z0-9_π']*)(?::([A-Za-z0-9_]+))?$",
                    "captures": {
                        "1": {
                            "name": "variable.other.source.gnn"
                        },
                        "2": {
                            "name": "variable.other.target.gnn"
                        },
                        "3": {
                            "name": "entity.name.tag.annotation.gnn"
                        }
                    }
                }
            ]
        },
        "parameterization": {
            "patterns": [
                {
                    "name": "meta.assignment.gnn",
                    "match": "^([A-Za-z_π'][A-Za-z0-9_π']*)=\\{",
                    "captures": {
                        "1": {
                            "name": "variable.other.assigned.gnn"
                        }
                    }
                },
                {
                    "name": "constant.numeric.float.gnn",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.gnn",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.gnn",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.other.version.gnn",
                    "match": "GNN v[0-9]+\\.?[0-9]*"
                }
            ]
        }
    }
}