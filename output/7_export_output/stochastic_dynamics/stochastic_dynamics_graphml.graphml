<?xml version="1.0" ?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns">
  <key id="d0" for="node" attr.name="label" attr.type="string"/>
  <key id="d1" for="edge" attr.name="weight" attr.type="double"/>
  <graph id="G" edgedefault="directed">
    <node id="n0">
      <data key="d0">x</data>
    </node>
    <node id="n1">
      <data key="d0">o</data>
    </node>
    <node id="n2">
      <data key="d0">u</data>
    </node>
    <node id="n3">
      <data key="d0">F</data>
    </node>
    <node id="n4">
      <data key="d0">G</data>
    </node>
    <node id="n5">
      <data key="d0">H</data>
    </node>
    <node id="n6">
      <data key="d0">gamma_state</data>
    </node>
    <node id="n7">
      <data key="d0">gamma_obs</data>
    </node>
    <node id="n8">
      <data key="d0">epsilon_state</data>
    </node>
    <node id="n9">
      <data key="d0">epsilon_obs</data>
    </node>
    <edge id="e0" source="" target=""/>
    <edge id="e1" source="" target=""/>
    <edge id="e2" source="" target=""/>
    <edge id="e3" source="" target=""/>
    <edge id="e4" source="" target=""/>
    <edge id="e5" source="" target=""/>
  </graph>
</graphml>
