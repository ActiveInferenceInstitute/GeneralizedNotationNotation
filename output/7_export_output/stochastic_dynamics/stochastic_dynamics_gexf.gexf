<?xml version="1.0" ?>
<gexf xmlns="http://www.gexf.net/1.2draft" version="1.2">
  <meta lastmodifieddate="2024-01-01">
    <creator>GNN Pipeline</creator>
    <description>GNN Model Export</description>
  </meta>
  <graph mode="static" defaultedgetype="directed">
    <nodes>
      <node id="n0" label="x"/>
      <node id="n1" label="o"/>
      <node id="n2" label="u"/>
      <node id="n3" label="F"/>
      <node id="n4" label="G"/>
      <node id="n5" label="H"/>
      <node id="n6" label="gamma_state"/>
      <node id="n7" label="gamma_obs"/>
      <node id="n8" label="epsilon_state"/>
      <node id="n9" label="epsilon_obs"/>
    </nodes>
    <edges>
      <edge id="e0" source="" target=""/>
      <edge id="e1" source="" target=""/>
      <edge id="e2" source="" target=""/>
      <edge id="e3" source="" target=""/>
      <edge id="e4" source="" target=""/>
      <edge id="e5" source="" target=""/>
    </edges>
  </graph>
</gexf>
