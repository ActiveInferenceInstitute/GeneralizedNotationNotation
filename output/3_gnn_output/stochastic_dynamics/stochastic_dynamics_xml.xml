    <mapping term="ProcessNoisePrecision" variable="gamma_state"/>
    <mapping term="ContinuousObservation" variable="o"/>
    <mapping term="ContinuousAction" variable="u"/>
    <mapping term="ContinuousHiddenState" variable="x"/>
  </ontology_mappings>
