    <variable data_type="integer" dimensions="1" name="t" type="hidden_state"/>
    <variable data_type="integer" dimensions="1" name="u" type="action" description="Selected action"/>
    <variable data_type="float" dimensions="2" name="π" type="policy" description="Policy (2 actions: move/stay)"/>
