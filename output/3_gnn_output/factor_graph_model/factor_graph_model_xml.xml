    <variable data_type="float" dimensions="6,3" name="A_vis" type="action" description="Visual likelihood factor: P(o_vis | s_pos)"/>
    <variable data_type="float" dimensions="3,3,2" name="B_pos" type="hidden_state" description="Position transition factor"/>
    <variable data_type="float" dimensions="2,2,1" name="B_vel" type="hidden_state" description="Velocity transition (action-independent)"/>
    <variable data_type="float" dimensions="4" name="C_prop" type="hidden_state" description="Proprioceptive preferences (comfort)"/>
    <variable data_type="float" dimensions="6" name="C_vis" type="hidden_state" description="Visual preferences (goal location)"/>
    <variable data_type="float" dimensions="3" name="D_pos" type="hidden_state" description="Prior over position"/>
    <variable data_type="float" dimensions="2" name="D_vel" type="hidden_state" description="Prior over velocity"/>
    <variable data_type="float" dimensions="1" name="F" type="hidden_state" description="Total Variational Free Energy (sum of factors)"/>
    <variable data_type="float" dimensions="1" name="G" type="policy" description="Expected Free Energy"/>
    <variable data_type="float" dimensions="3,1" name="m_pos_to_vis" type="hidden_state" description="Message: position→visual factor"/>
    <variable data_type="float" dimensions="2,1" name="m_prop_to_vel" type="hidden_state" description="Message: proprioceptive factor→velocity"/>
