      <sources>C</sources>
      <targets>G</targets>
    </connection>
    <connection type="directed">
      <sources>D</sources>
      <targets>s</targets>
    </connection>
    <connection type="directed">
      <sources>G</sources>
      <targets>π</targets>
    </connection>
    <connection type="undirected">
      <sources>s</sources>
      <targets>A</targets>
    </connection>
    <connection type="undirected">
      <sources>s</sources>
      <targets>B</targets>
    </connection>
    <connection type="directed">
      <sources>s</sources>
      <targets>s_prime</targets>
    </connection>
    <connection type="directed">
      <sources>u</sources>
      <targets>s_prime</targets>
    </connection>
    <connection type="directed">
      <sources>π</sources>
      <targets>u</targets>
    </connection>
  </connections>
  <parameters>
    <parameter name="A">[[0.1, 0.5, 0.5], [0.3, 0.4, 0.3], [0.6, 0.1, 0.2]]</parameter>
    <parameter name="B">[[[0.9, 0.05, 0.05], [0.05, 0.9, 0.05], [0.05, 0.05, 0.9]], [[0.9, 0.05, 0.05], [0.05, 0.9, 0.05], [0.05, 0.05, 0.9]], [[0.9, 0.05, 0.05], [0.05, 0.9, 0.05], [0.05, 0.05, 0.9]]]</parameter>
    <parameter name="C">[[0.0, 1.0, 3.0]]</parameter>
    <parameter name="D">[[0.33333, 0.33333, 0.33333]]</parameter>
  </parameters>
  <time_specification horizon="Unbounded" type="Dynamic"/>
  <ontology_mappings>
