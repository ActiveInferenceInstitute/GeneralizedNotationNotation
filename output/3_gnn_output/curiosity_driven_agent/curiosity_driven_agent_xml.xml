    <variable data_type="integer" dimensions="1" name="t" type="hidden_state" description="Discrete time step"/>
    <variable data_type="integer" dimensions="1" name="u" type="action" description="Selected action"/>
    <variable data_type="float" dimensions="1" name="γ" type="hidden_state" description="Precision weighting epistemic vs instrumental value"/>
    <variable data_type="float" dimensions="4" name="π" type="policy" description="Policy distribution over actions"/>
  </variables>
