    <variable data_type="float" dimensions="1" name="G" type="policy" description="Total Expected Free Energy (epistemic + instrumental)"/>
    <variable data_type="float" dimensions="1" name="G_epi" type="policy" description="Epistemic value component (information gain)"/>
    <variable data_type="float" dimensions="1" name="G_ins" type="hidden_state" description="Instrumental value component (preference satisfaction)"/>
