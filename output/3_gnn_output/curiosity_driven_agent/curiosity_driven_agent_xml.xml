<?xml version="1.0" ?>
<gnn_model name="Curiosity-Driven Active Inference Agent" version="1.0">
  <metadata>
    <annotation>An Active Inference agent with:
- Explicit epistemic value (information gain / Bayesian surprise) component in G
- Separate instrumental value (preference satisfaction) component
- Precision parameter γ weighting epistemic vs instrumental contributions
- 5 hidden states, 5 observations, 4 actions in a navigation context
- Agent is rewarded for reducing posterior uncertainty</annotation>
    <created_at>2026-04-14T11:53:27.265491</created_at>
    <modified_at>2026-04-14T11:53:27.265492</modified_at>
  </metadata>
  <variables>
