  "extensions": {
    "gnn_section": "ActInfPOMDP_MultiAgent",
    "footer": "Stigmergic Swarm Active Inference v1 - GNN Representation.\n3 agents coordinating via environmental traces only.\nNo direct communication \u2014 emergent coordination from shared signals.\nModels ant colony foraging and decentralized robotic coordination.",
    "signature": "Cryptographic signature goes here"
