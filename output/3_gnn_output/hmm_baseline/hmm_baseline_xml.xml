    <variable data_type="float" dimensions="4,1" name="beta" type="hidden_state" description="Backward variable"/>
    <variable data_type="integer" dimensions="6,1" name="o" type="observation" description="Current observation (one-hot)"/>
    <variable data_type="float" dimensions="4,1" name="s" type="hidden_state" description="Hidden state belief (posterior)"/>
    <variable data_type="float" dimensions="4,1" name="s_prime" type="hidden_state" description="Next hidden state"/>
    <variable data_type="integer" dimensions="1" name="t" type="hidden_state" description="Discrete time step"/>
