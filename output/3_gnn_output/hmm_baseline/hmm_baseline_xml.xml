    <variable data_type="float" dimensions="4,4" name="B" type="transition_matrix" description="Transition matrix (no action dependence)"/>
    <variable data_type="float" dimensions="4" name="D" type="prior_vector" description="Initial state distribution (prior)"/>
    <variable data_type="float" dimensions="1" name="F" type="hidden_state" description="Variational Free Energy (negative ELBO)"/>
