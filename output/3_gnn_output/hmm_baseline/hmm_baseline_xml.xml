<gnn_model name="Hidden Markov Model Baseline" version="1.0">
  <metadata>
    <annotation>A standard discrete Hidden Markov Model with:
- 4 hidden states with Markovian dynamics
- 6 observation symbols
- Fixed transition and emission matrices
- No action selection (passive inference only)
- Suitable for sequence modeling and state estimation tasks</annotation>
    <created_at>2026-04-15T12:25:54.012082</created_at>
    <modified_at>2026-04-15T12:25:54.012084</modified_at>
  </metadata>
  <variables>
