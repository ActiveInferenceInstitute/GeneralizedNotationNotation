<?xml version="1.0" ?>
<gnn_model name="Static Perception Model" version="1.0">
  <metadata>
    <annotation>The simplest Active Inference model demonstrating pure perception:
- 2 hidden states mapped to 2 observations via a recognition matrix A
- Prior D encodes initial beliefs over hidden states
- No temporal dynamics — single-shot inference
- Demonstrates the core observation model: P(o|s) = A
- Suitable as a minimal baseline and for testing perception-only inference</annotation>
    <created_at>2026-04-15T12:25:52.479319</created_at>
    <modified_at>2026-04-15T12:25:52.479320</modified_at>
  </metadata>
  <variables>
    <variable data_type="float" dimensions="2,2" name="A" type="likelihood_matrix" description="Recognition/likelihood matrix: P(observation | hidden state)"/>
    <variable data_type="float" dimensions="2,1" name="D" type="prior_vector" description="Prior belief over hidden states"/>
    <variable data_type="integer" dimensions="2,1" name="o" type="observation" description="Observation (one-hot encoded)"/>
    <variable data_type="float" dimensions="2,1" name="s" type="hidden_state" description="Hidden state (posterior belief)"/>
  </variables>
  <connections>
    <connection type="undirected">
      <sources>A</sources>
      <targets>o</targets>
    </connection>
    <connection type="directed">
      <sources>D</sources>
      <targets>s</targets>
    </connection>
    <connection type="undirected">
      <sources>s</sources>
      <targets>A</targets>
    </connection>
  </connections>
  <parameters>
    <parameter name="A">[[0.9, 0.1], [0.2, 0.8]]</parameter>
    <parameter name="D">[[0.5, 0.5]]</parameter>
  </parameters>
  <time_specification type="Static"/>
  <ontology_mappings>
    <mapping term="RecognitionMatrix" variable="A"/>
    <mapping term="Prior" variable="D"/>
    <mapping term="Observation" variable="o"/>
    <mapping term="HiddenState" variable="s"/>
  </ontology_mappings>
