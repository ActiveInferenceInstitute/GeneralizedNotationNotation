<?xml version="1.0" ?>
<gnn_model name="Precision-Weighted Active Inference Agent" version="1.0">
  <metadata>
    <annotation>An Active Inference agent with explicit precision parameters:
- ω (omega): sensory precision weighting likelihood confidence
- γ (gamma): policy precision controlling action randomness
- β (beta): inverse temperature for policy selection (softmax)
- 3 hidden states, 3 observations, 3 actions (same topology as base POMDP)
- Precision parameters enable modeling of attention and confidence</annotation>
    <created_at>2026-03-06T15:00:17.104042</created_at>
    <modified_at>2026-03-06T15:00:17.104042</modified_at>
  </metadata>
  <variables>
