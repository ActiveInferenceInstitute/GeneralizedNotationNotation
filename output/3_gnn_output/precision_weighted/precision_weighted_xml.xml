    <variable data_type="float" dimensions="3,3,3" name="B" type="transition_matrix" description="Transition matrix"/>
    <variable data_type="float" dimensions="3" name="C" type="preference_vector" description="Log-preferences over observations"/>
    <variable data_type="float" dimensions="3" name="D" type="prior_vector" description="Prior over hidden states"/>
    <variable data_type="float" dimensions="3" name="E" type="policy" description="Habit (prior over actions)"/>
