    <variable data_type="float" dimensions="1" name="γ" type="hidden_state" description="Policy precision (temperature for action selection)"/>
    <variable data_type="float" dimensions="3" name="π" type="policy" description="Policy distribution"/>
    <variable data_type="float" dimensions="1" name="ω" type="hidden_state" description="Sensory precision (modulates A matrix confidence)"/>
  </variables>
