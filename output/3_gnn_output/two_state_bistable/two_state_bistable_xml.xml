      <sources>E</sources>
      <targets>π</targets>
    </connection>
    <connection type="directed">
      <sources>G</sources>
      <targets>π</targets>
    </connection>
    <connection type="undirected">
      <sources>s</sources>
      <targets>A</targets>
    </connection>
    <connection type="undirected">
      <sources>s</sources>
      <targets>B</targets>
    </connection>
    <connection type="directed">
      <sources>s</sources>
      <targets>s_prime</targets>
    </connection>
    <connection type="directed">
      <sources>u</sources>
      <targets>s_prime</targets>
    </connection>
    <connection type="directed">
      <sources>π</sources>
      <targets>u</targets>
    </connection>
  </connections>
  <parameters>
    <parameter name="A">[[0.8, 0.2], [0.2, 0.8]]</parameter>
    <parameter name="B">[[[0.8, 0.3], [0.2, 0.7]], [[0.3, 0.8], [0.7, 0.2]]]</parameter>
    <parameter name="C">[[0.0, 2.0]]</parameter>
    <parameter name="D">[[0.5, 0.5]]</parameter>
    <parameter name="E">[[0.5, 0.5]]</parameter>
  </parameters>
  <time_specification horizon="Unbounded" type="Dynamic"/>
