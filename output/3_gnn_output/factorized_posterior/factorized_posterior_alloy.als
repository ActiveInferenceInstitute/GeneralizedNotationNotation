  value: Int,
  dimensions: seq Int  // [2, 1]
}

sig s_f0 {
  value: Int,
  dimensions: seq Int  // [4, 1]
}

sig s_f1 {
  value: Int,
  dimensions: seq Int  // [2, 1]
}

sig u {
  value: Int,
  dimensions: seq Int  // [3, 1]
}

// Connection constraints
fact Connections {
  // Connection 1: D_f0 -> s_f0
  some D_f0 and some s_f0
  // Connection 2: D_f1 -> s_f1
  some D_f1 and some s_f1
  // Connection 3: s_f0 -> B_f0
  some s_f0 and some B_f0
  // Connection 3: u -> B_f0
  some u and some B_f0
  // Connection 4: B_f0 -> s_f0
  some B_f0 and some s_f0
  // Connection 5: s_f1 -> B_f1
  some s_f1 and some B_f1
  // Connection 6: B_f1 -> s_f1
  some B_f1 and some s_f1
  // Connection 7: s_f0 -> A_m0
  some s_f0 and some A_m0
  // Connection 7: s_f1 -> A_m0
  some s_f1 and some A_m0
  // Connection 8: A_m0 -> o_m0
  some A_m0 and some o_m0
  // Connection 9: s_f0 -> A_m1
  some s_f0 and some A_m1
  // Connection 10: A_m1 -> o_m1
  some A_m1 and some o_m1
  // Connection 11: C_m0 -> o_m0
  some C_m0 and some o_m0
  // Connection 12: C_m1 -> o_m1
  some C_m1 and some o_m1
}

// Model validity predicate
pred Factorized_Posterior_AgentValid {
  // All variables must exist
  some s_f0
  some s_f1
  some o_m0
  some o_m1
  some u
  some A_m0
  some A_m1
  some B_f0
  some B_f1
  some D_f0
  some D_f1
  some C_m0
  some C_m1
}

