  value: Int,
  dimensions: seq Int  // [2, 2]
}

sig C_m0 {
  value: Int,
  dimensions: seq Int  // [3, 1]
}

sig C_m1 {
  value: Int,
  dimensions: seq Int  // [2, 1]
}

sig D_f0 {
  value: Int,
  dimensions: seq Int  // [4, 1]
}

