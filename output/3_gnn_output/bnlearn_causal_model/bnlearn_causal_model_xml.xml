<?xml version="1.0" ?>
<gnn_model name="Bnlearn Causal Model" version="1.0">
  <metadata>
    <annotation>A Bayesian Network model mapping Active Inference structure:
- S: Hidden State
- A: Action
- S_prev: Previous State
- O: Observation</annotation>
    <created_at>2026-04-14T11:53:26.058378</created_at>
    <modified_at>2026-04-14T11:53:26.058381</modified_at>
  </metadata>
  <variables>
    <variable data_type="float" dimensions="2,2" name="A" type="likelihood_matrix" description="P(O | S)"/>
    <variable data_type="float" dimensions="2,2,2" name="B" type="transition_matrix" description="P(S | S_prev, A)"/>
    <variable data_type="integer" dimensions="2,1" name="a" type="action"/>
    <variable data_type="integer" dimensions="2,1" name="o" type="observation"/>
    <variable data_type="float" dimensions="2,1" name="s" type="hidden_state"/>
    <variable data_type="float" dimensions="2,1" name="s_prev" type="hidden_state"/>
  </variables>
  <connections>
    <connection type="directed">
      <sources>a</sources>
      <targets>s</targets>
    </connection>
    <connection type="directed">
      <sources>s</sources>
      <targets>o</targets>
    </connection>
    <connection type="directed">
      <sources>s_prev</sources>
      <targets>s</targets>
    </connection>
  </connections>
  <parameters>
    <parameter name="A">[[0.9, 0.1], [0.1, 0.9]]</parameter>
    <parameter name="B">[[[0.7, 0.3], [0.3, 0.7]], [[0.3, 0.7], [0.7, 0.3]]]</parameter>
    <parameter name="C">[[0.0, 1.0]]</parameter>
    <parameter name="D">[[0.5, 0.5]]</parameter>
  </parameters>
  <time_specification type="Dynamic"/>
  <ontology_mappings>
    <mapping term="ObservationModel" variable="A"/>
    <mapping term="TransitionModel" variable="B"/>
    <mapping term="Action" variable="a"/>
    <mapping term="Observation" variable="o"/>
    <mapping term="HiddenState" variable="s"/>
    <mapping term="PreviousState" variable="s_prev"/>
  </ontology_mappings>
