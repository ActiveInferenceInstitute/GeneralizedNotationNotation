{
  "scopeName": "source.gnn",
  "name": "Generalized Notation Notation",
  "patterns": [
    {
      "match": "#.*$",
      "name": "comment.line.number-sign.gnn"
    },
    {
      "match": "\\b(ModelName|Version|Type)\\b",
      "name": "keyword.control.gnn"
    },
    {
      "match": "\\b(StateSpace|Observations|Actions|Prior|Preferences)\\b",
      "name": "entity.name.section.gnn"
    },
    {
      "match": "\\b[A-Za-z0-9_]+\\s*(?=:)",
      "name": "variable.other.gnn"
    },
    {
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
      "name": "constant.numeric.gnn"
    },
    {
      "match": "\"(?:[^\"]|\\\\\")*\"",
      "name": "string.quoted.double.gnn"
    },
    {
      "match": "'(?:[^']|\\\\')*'",
      "name": "string.quoted.single.gnn"
    }
  ]
}
